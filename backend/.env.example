# ── Supabase ──────────────────────────────────────────────────
# Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Settings → API → service_role key (NOT the anon key)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Groq ──────────────────────────────────────────────────────
# console.groq.com/keys
GROQ_API_KEY=gsk_...

# ── Stripe ────────────────────────────────────────────────────
# Developers → API keys → Secret key
STRIPE_SECRET_KEY=sk_test_...

# Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Products → each product → Pricing → Price ID
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_STANDARD=price_...
STRIPE_PRICE_PRO=price_...

# ── App ───────────────────────────────────────────────────────
PORT=3001

# URL shown in Stripe checkout success/cancel redirect
FRONTEND_URL=http://localhost:3001
