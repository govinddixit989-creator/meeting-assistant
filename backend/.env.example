# ── Supabase ──────────────────────────────────────────────────
# Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Settings → API → service_role key (NOT the anon key)
SUPABASE_SERVICE_KEY=sb_secret_...

# ── Groq ──────────────────────────────────────────────────────
# console.groq.com/keys
GROQ_API_KEY=gsk_...

# ── Email (Brevo SMTP) ────────────────────────────────────────
# app.brevo.com → SMTP & API → SMTP → Generate new SMTP key
BREVO_USER=you@gmail.com
BREVO_SMTP_KEY=xsmtpsib-...

# ── Admin secret (protects /codes/send endpoint) ───────────────
ADMIN_SECRET=change-me-to-something-secret

# ── App ───────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3001
